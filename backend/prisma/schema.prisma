generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  technical_specialist
  guest
}

enum UserStatus {
  pending
  active
  blocked
}

enum DeviceStatus {
  active
  in_repair
  in_calibration
  ready_for_handover
  handed_over
  needs_calibration
  written_off
}

enum ServiceCycleType {
  repair
  calibration
}

enum ServiceCycleStatus {
  created
  in_progress
  sop_passed
  sop_failed
  depot_passed
  depot_failed
  ready_for_handover
  handed_over
  cancelled
}

model User {
  id               String         @id @default(cuid())
  fullName         String
  email            String         @unique
  passwordHash     String
  role             UserRole       @default(technical_specialist)
  status           UserStatus     @default(pending)
  createdAt        DateTime       @default(now())
  createdCycles    ServiceCycle[] @relation("CycleCreator")
  handedOverCycles ServiceCycle[] @relation("CycleHandover")
  auditLogs        AuditLog[]

  @@map("users")
}

model Device {
  id             String         @id @default(cuid())
  serialNumber   String         @unique
  name           String
  category       String?
  photoUrl       String?
  description    String?
  currentStatus  DeviceStatus   @default(active)
  isWrittenOff   Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  serviceCycles  ServiceCycle[]

  @@map("devices")
}

model ServiceCycle {
  id                 String             @id @default(cuid())
  deviceId           String
  device             Device             @relation(fields: [deviceId], references: [id])
  type               ServiceCycleType
  status             ServiceCycleStatus @default(created)
  sopCheck           Boolean?
  depotCheck         Boolean?
  readyForHandover   Boolean            @default(false)
  handedOverAt       DateTime?
  handedOverByUserId String?
  handedOverBy       User?              @relation("CycleHandover", fields: [handedOverByUserId], references: [id])
  comment            String?
  createdByUserId    String
  createdBy          User               @relation("CycleCreator", fields: [createdByUserId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  closedAt           DateTime?

  @@index([deviceId])
  @@index([createdByUserId])
  @@index([handedOverByUserId])
  @@map("service_cycles")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
